{
  "name": "santiago-moraes",
  "version": "1.0.0",
  "description": "Tema personalizado para Santiago Moraes",
  "scripts": {
    "sass:build": "sass assets/scss/style.scss assets/css/style.css --style=compressed --no-source-map",
    "sass:dev": "sass assets/scss/style.scss assets/css/style.css --style=expanded --source-map-urls=relative",
    "sass:watch": "sass assets/scss/style.scss assets/css/style.css --watch --style=expanded --source-map-urls=relative",
    "dev": "npm run sass:watch",
    "build": "npm run sass:build"
  },
  "devDependencies": {
    "sass": "^1.83.0"
  }
}
