{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sm/album-grid",
	"version": "1.0.0",
	"title": "Discografía",
	"category": "santiago-moraes",
	"icon": "album",
	"description": "Grid de álbumes de la taxonomía album.",
	"textdomain": "santiago-moraes",
	"attributes": {
		"columns": {
			"type": "number",
			"default": 2,
			"enum": [ 2, 3 ]
		},
		"showDemos": {
			"type": "boolean",
			"default": false
		},
		"showYear": {
			"type": "boolean",
			"default": true
		}
	},
	"supports": {
		"html": false,
		"anchor": true
	},
	"render": "file:./render.php"
}
