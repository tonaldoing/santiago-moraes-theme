{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "1140px",
			"wideSize": "1440px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{
					"slug": "dark",
					"color": "#1B110D",
					"name": "Oscuro"
				},
				{
					"slug": "black",
					"color": "#010101",
					"name": "Negro"
				},
				{
					"slug": "white",
					"color": "#FFFFFF",
					"name": "Blanco"
				},
				{
					"slug": "cream",
					"color": "#F7F3F0",
					"name": "Crema"
				},
				{
					"slug": "accent",
					"color": "#EC4913",
					"name": "Acento"
				},
				{
					"slug": "secondary",
					"color": "#9A5F4C",
					"name": "Secundario"
				},
				{
					"slug": "border",
					"color": "#E7D5CF",
					"name": "Borde"
				},
				{
					"slug": "body",
					"color": "#0A0A0A",
					"name": "Cuerpo"
				},
				{
					"slug": "bg-light",
					"color": "#54200F",
					"name": "Fondo Claro"
				},
				{
					"slug": "box",
					"color": "#F7F3F0",
					"name": "Fondo Cajas"
				},
				{
					"slug": "heading",
					"color": "#1B110D",
					"name": "Títulos"
				}
			]
		},
		"typography": {
			"dropCap": false,
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"fontFamily": "'Be Vietnam Pro', sans-serif",
					"slug": "primary",
					"name": "Be Vietnam Pro"
				},
				{
					"fontFamily": "'Montserrat', sans-serif",
					"slug": "body",
					"name": "Montserrat"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "14px",
					"name": "Chico"
				},
				{
					"slug": "medium",
					"size": "16px",
					"name": "Mediano"
				},
				{
					"slug": "large",
					"size": "20px",
					"name": "Grande"
				},
				{
					"slug": "x-large",
					"size": "36px",
					"name": "Extra Grande"
				},
				{
					"slug": "xx-large",
					"size": "72px",
					"name": "Hero"
				}
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "vw", "%"]
		}
	},
	"styles": {
		"color": {
			"background": "var(--color-white)",
			"text": "var(--color-body)"
		},
		"typography": {
			"fontFamily": "var(--font-body)",
			"fontSize": "16px",
			"lineHeight": "1.6"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--font-heading)",
					"fontWeight": "700"
				},
				"color": {
					"text": "var(--color-heading)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "72px",
					"fontWeight": "900",
					"lineHeight": "1em",
					"letterSpacing": "-3.6px"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "36px",
					"lineHeight": "40px",
					"letterSpacing": "-0.9px"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "20px",
					"lineHeight": "28px",
					"letterSpacing": "-0.5px"
				}
			},
			"link": {
				"color": {
					"text": "var(--color-accent)"
				},
				":hover": {
					"color": {
						"text": "var(--color-dark)"
					}
				}
			},
			"button": {
				"typography": {
					"fontFamily": "var(--font-button)",
					"fontSize": "14px",
					"fontWeight": "500"
				},
				"color": {
					"background": "var(--color-accent)",
					"text": "var(--color-white)"
				},
				"border": {
					"radius": "8px"
				}
			}
		}
	}
}
